CREATE TABLE `clients` (
  `id` INT AUTO_INCREMENT PRIMARY KEY,
  `client_name` VARCHAR(255),
  `source` VARCHAR(100),
  `contact_person` VARCHAR(255),
  'position' VARCHAR(255).
  `phone` VARCHAR(100),
  `status` VARCHAR(50),
  `manager_id` INT,
  'manager_FIO' VARCHAR(500), 
  `updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

ALTER TABLE `clients` 
ADD COLUMN `first_contact_date` DATE,
ADD COLUMN `email` VARCHAR(100),
ADD COLUMN `comment` TEXT,
ADD COLUMN `next_contact_date` DATE,
MODIFY COLUMN `source` VARCHAR(255);
ALTER TABLE `clients` ADD COLUMN `is_contract_signed` TINYINT(1) DEFAULT 0;

ALTER TABLE `projects` ADD COLUMN `ttn_number` VARCHAR(100) DEFAULT NULL;
ALTER TABLE 'projects' ADD COLUMN 'ttn_date' DATE(100) DEFAULT NULL;


CREATE TABLE project_ttns (
    id INT AUTO_INCREMENT PRIMARY KEY,
    project_id INT NOT NULL,
    ttn_number VARCHAR(100),
    ttn_date DATE,
    product_info TEXT, -- Какая продукция в этой ТТН
    FOREIGN KEY (project_id) REFERENCES projects(id) ON DELETE CASCADE
);

-- Добавляем поле для скана договора в проекты
ALTER TABLE projects ADD COLUMN contract_file VARCHAR(255) DEFAULT NULL;

-- Добавляем Источник в таблицу клиентов
ALTER TABLE clients ADD COLUMN lead_source VARCHAR(100) DEFAULT 'Холодный звонок';

ALTER TABLE `project_ttns` ADD COLUMN IF NOT EXISTS `amount` DECIMAL(15,2) DEFAULT 0.00;
